{
  "name": "dynamodb-toolkit-lambda",
  "version": "0.3.0",
  "description": "AWS Lambda adapter for dynamodb-toolkit — serves the standard REST route pack as a Lambda handler for API Gateway (REST / HTTP), Lambda Function URLs, and ALB. Delegates parsing, envelope building, and policy to dynamodb-toolkit/rest-core.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./*": "./src/*"
  },
  "scripts": {
    "test": "tape6 --flags FO",
    "test:bun": "tape6-bun --flags FO",
    "test:deno": "tape6-deno --flags FO",
    "ts-test": "tape6 --flags FO tests/test-*.*ts",
    "ts-test:bun": "tape6-bun --flags FO tests/test-*.*ts",
    "ts-test:deno": "tape6-deno --flags FO tests/test-*.*ts",
    "ts-check": "tsc --noEmit",
    "js-check": "tsc --project tsconfig.check.json",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "tape6": {
    "tests": [
      "/tests/test-*.js",
      "/tests/test-*.mjs"
    ],
    "node": [
      "/tests/test-*.cjs"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/dynamodb-toolkit-lambda.git"
  },
  "keywords": [
    "aws",
    "aws-lambda",
    "lambda",
    "dynamodb",
    "aws-sdk",
    "aws-sdk-v3",
    "api-gateway",
    "api-gateway-v1",
    "api-gateway-v2",
    "function-urls",
    "alb",
    "serverless",
    "adapter",
    "dynamodb-toolkit",
    "toolkit",
    "rest",
    "crud",
    "pagination",
    "hooks",
    "http",
    "event",
    "typescript",
    "esm",
    "zero-dependencies",
    "node",
    "edge"
  ],
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (http://lazutkin.com)",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/uhop/dynamodb-toolkit-lambda/issues"
  },
  "homepage": "https://github.com/uhop/dynamodb-toolkit-lambda#readme",
  "funding": "https://github.com/sponsors/uhop",
  "llms": "https://raw.githubusercontent.com/uhop/dynamodb-toolkit-lambda/master/llms.txt",
  "llmsFull": "https://raw.githubusercontent.com/uhop/dynamodb-toolkit-lambda/master/llms-full.txt",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "dynamodb-toolkit": "^3.7.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1031.0",
    "@aws-sdk/lib-dynamodb": "^3.1031.0",
    "@types/aws-lambda": "^8.10.155",
    "@types/node": "^25.6.0",
    "dynamodb-toolkit": "^3.7.0",
    "prettier": "^3.8.1",
    "tape-six": "^1.7.13",
    "typescript": "^6.0.3"
  },
  "files": [
    "src",
    "llms.txt",
    "llms-full.txt"
  ]
}
